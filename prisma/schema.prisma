generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String              @id @default(uuid())
  name            String?
  email           String              @unique
  password        String?
  role            RoleType            @default(CUSTOMER)
  referralCode    String?             @unique
  referredBy      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  authProvider    AuthProvider        @default(EMAIL)
  emailVerifiedAt DateTime?
  isVerified      Boolean             @default(false)
  pendingEmail    String?             @unique
  profileImageUrl String?
  addresses       Address[]
  carts           Cart[]
  orders          Order[]
  socialAccounts  SocialAccount[]
  storeAdmins     StoreAdmin[]
  referrer        User?               @relation("Referral", fields: [referredBy], references: [id])
  referredUser    User[]              @relation("Referral")
  vouchers        UserVoucher[]
  tokens          VerificationToken[]
}

model VerificationToken {
  id        String                @id @default(uuid())
  userId    String
  tokenHash String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  newEmail  String?
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

model Address {
  id        String     @id @default(uuid())
  userId    String
  label     String
  receiver  String
  phone     String
  address   String
  province  String
  city      String
  district  String
  latitude  Float
  longitude Float
  isPrimary Boolean    @default(false)
  createdAt DateTime   @default(now())
  deletedAt DateTime?
  user      User       @relation(fields: [userId], references: [id])
  orders    Order[]
  shippings Shipping[]
}

model Store {
  id          String       @id @default(uuid())
  name        String
  address     String
  latitude    Float
  longitude   Float
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  cartItems   CartItem[]
  inventories Inventory[]
  orders      Order[]
  shippings   Shipping[]
  admins      StoreAdmin[]
}

model StoreAdmin {
  id        String    @id @default(uuid())
  storeId   String
  userId    String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  store     Store     @relation(fields: [storeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([storeId, userId])
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  imageUrl  String?
  products  Product[]
}

model Product {
  id            String         @id @default(uuid())
  categoryId    String
  name          String
  slug          String         @unique
  description   String?
  price         Decimal        @db.Decimal(14, 2)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  cartItems     CartItem[]
  inventories   Inventory[]
  orderItems    OrderItem[]
  category      Category       @relation(fields: [categoryId], references: [id])
  productImages ProductImage[]
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model Inventory {
  id        String          @id @default(uuid())
  storeId   String
  productId String
  stock     Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  product   Product         @relation(fields: [productId], references: [id])
  store     Store           @relation(fields: [storeId], references: [id])
  mutations StockMutation[]

  @@unique([storeId, productId])
}

model StockMutation {
  id            String       @id @default(uuid())
  inventoryId   String
  type          MutationType
  quantity      Int
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime     @default(now())
  inventory     Inventory    @relation(fields: [inventoryId], references: [id])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id            String  @id @default(uuid())
  cartId        String
  productId     String
  storeId       String
  quantity      Int
  priceSnapshot Decimal @db.Decimal(14, 2)
  cart          Cart    @relation(fields: [cartId], references: [id])
  product       Product @relation(fields: [productId], references: [id])
  store         Store   @relation(fields: [storeId], references: [id])

  @@unique([cartId, productId, storeId])
}

model Voucher {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  type         VoucherType
  value        Decimal       @db.Decimal(14, 2)
  minPurchase  Decimal?      @db.Decimal(14, 2)
  startDate    DateTime
  endDate      DateTime
  totalQuota   Int?
  usedQuota    Int           @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orders       Order[]
  userVouchers UserVoucher[]
}

model UserVoucher {
  id        String    @id @default(uuid())
  userId    String
  voucherId String
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  voucher   Voucher   @relation(fields: [voucherId], references: [id])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  addressId      String
  storeId        String
  voucherId      String?
  status         OrderStatus @default(WAITING_PAYMENT)
  subtotal       Decimal     @db.Decimal(14, 2)
  discountAmount Decimal     @default(0) @db.Decimal(14, 2)
  shippingCost   Decimal     @db.Decimal(14, 2)
  totalAmount    Decimal     @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  address        Address     @relation(fields: [addressId], references: [id])
  store          Store       @relation(fields: [storeId], references: [id])
  user           User        @relation(fields: [userId], references: [id])
  voucher        Voucher?    @relation(fields: [voucherId], references: [id])
  items          OrderItem[]
  payment        Payment?
  shipping       Shipping?
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  productName   String
  priceSnapshot Decimal @db.Decimal(14, 2)
  quantity      Int
  subtotal      Decimal @db.Decimal(14, 2)
  order         Order   @relation(fields: [orderId], references: [id])
  product       Product @relation(fields: [productId], references: [id])
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  amount        Decimal       @db.Decimal(14, 2)
  bankName      String?
  accountNumber String?
  proofUrl      String
  status        PaymentStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         Order         @relation(fields: [orderId], references: [id])
}

model Shipping {
  id                   String   @id @default(uuid())
  orderId              String   @unique
  courier              String
  service              String
  originStoreId        String
  destinationAddressId String
  shippingCost         Decimal  @db.Decimal(14, 2)
  resi                 String?
  status               String   @default("CALCULATED")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  destinationAddress   Address  @relation(fields: [destinationAddressId], references: [id])
  order                Order    @relation(fields: [orderId], references: [id])
  originStore          Store    @relation(fields: [originStoreId], references: [id])
}

model SocialAccount {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  email          String
  avatarUrl      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([email])
}

enum RoleType {
  SUPER_ADMIN
  STORE_ADMIN
  CUSTOMER
}

enum MutationType {
  IN
  OUT
  TRANSFER
}

enum VoucherType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  RESET_PASSWORD
  EMAIL_CHANGE
}
